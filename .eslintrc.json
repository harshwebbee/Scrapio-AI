{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": ["node_modules/", "dist/", ".next/", "storage/"],
  "settings": {
    "next": {
      "rootDir": "apps/web/"
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": "off"
  },
  "overrides": [
    {
      "files": ["apps/api/**/*.ts", "packages/**/*.ts"],
      "extends": ["eslint:recommended"],
      "plugins": ["@typescript-eslint"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "env": {
        "node": true,
        "es2022": true
      },
      "rules": {
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ]
      }
    }
  ]
}
