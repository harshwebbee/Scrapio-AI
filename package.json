{
  "name": "scrapio-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Scrapio AI MVP website crawler and AI-ready export tool.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "worker": "npm run worker -w apps/api",
    "infra:up": "docker compose up -d redis postgres",
    "infra:down": "docker compose down",
    "stack:up": "docker compose up -d redis postgres api worker web",
    "stack:down": "docker compose down",
    "build": "npm run build -w packages/scraper && npm run build -w apps/api && npm run build -w apps/web",
    "typecheck": "npm run build -w packages/scraper && tsc --noEmit",
    "test": "npm run build -w packages/scraper && node --test packages/scraper/dist/utils.test.js",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.12.10",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsdom": "^24.1.1",
    "next": "^14.2.5",
    "pg": "^8.22.0",
    "playwright": "^1.45.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
